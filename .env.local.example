# Vercel Connect connector UID for Linear. This MUST match a connector linked
# to your project. Find the exact UID with `vercel connect list` — it varies
# (e.g. `linear/yellow-house` for a managed Linear connector, or `oauth/linear`
# for a Custom OAuth connector). The app shows a "connector not found" hint if
# this doesn't match.
CONNECTOR=oauth/linear

# Stable demo subject id for the user-scoped Linear token.
# This template has no auth system, so a single constant keeps the Vercel
# Connect consent grant persistent across reloads. In a real app, set this to
# your signed-in user's id (ideally per-user, e.g. from a session cookie).
LINEAR_DEMO_USER_ID=demo-user

# VERCEL_OIDC_TOKEN is added automatically by `vercel env pull` and is what the
# @vercel/connect SDK uses to authenticate with Vercel Connect. Do not commit it.
